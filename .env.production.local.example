# SPORTIKON Arena - Production Environment Variables Template
# Copy this to .env.production.local on your production server
# Replace all YOUR_* values with actual production values

# ========================================
# SUPABASE DATABASE CONFIGURATION
# ========================================
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ========================================
# APPLICATION CONFIGURATION
# ========================================
# Your production domain - update this after deployment
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=SPORTIKON Arena

# Admin portal secret path - CHANGE THIS for security!
# Example: https://your-domain.com/secret-admin-12345/
NEXT_PUBLIC_ADMIN_SECRET_PATH=secret-admin-path-change-me

# ========================================
# PERFORMANCE & CACHING
# ========================================
# Cache revalidation time in seconds (production should be higher than dev)
CACHE_REVALIDATE_TIME=60

# Live score polling interval in milliseconds
# Increase this on production to reduce database load
LIVE_SCORE_POLL_INTERVAL=5000

# ========================================
# OPTIONAL: ANALYTICS & MONITORING
# ========================================
# NEXT_PUBLIC_GA_ID=your_google_analytics_id
# SENTRY_DSN=your_sentry_dsn_for_error_tracking

# ========================================
# NODE ENVIRONMENT
# ========================================
NODE_ENV=production

# ========================================
# NOTES FOR DEPLOYMENT
# ========================================
# 1. Get SUPABASE_URL and SUPABASE_ANON_KEY from:
#    Supabase Dashboard → Settings → API
#
# 2. Change NEXT_PUBLIC_ADMIN_SECRET_PATH to something random
#    Example: NEXT_PUBLIC_ADMIN_SECRET_PATH=/admin-xyz-123-abc
#    This prevents admin portal discovery by scanners
#
# 3. Update NEXT_PUBLIC_APP_URL to your actual domain
#    This is used for password reset links, etc.
#
# 4. Keep this file SECURE - never commit to Git
#    Add .env.production.local to .gitignore
#
# 5. On EC2, place this file at: ~/sportikon/.env.production.local
#    Permissions: chmod 600 .env.production.local
